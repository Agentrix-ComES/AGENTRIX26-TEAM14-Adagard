GEMINI_API_KEY=your_free_tier_key_here
EMBED_MODEL=models/gemini-embedding-001     # 768-d, used for pgvector RAG
LLM_MODEL=gemini-2.5-flash

# --- Auth / RBAC ---
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720
# Postgres (Prisma Postgres direct connection) in production; sqlite:///./govpath.db for local dev.
# The scheme is auto-normalized to psycopg (postgres:// -> postgresql+psycopg://).
DATABASE_URL=postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require
# Bootstrap super-admin (created on first startup if absent)
SUPERADMIN_NIC=199000000000
SUPERADMIN_PASSWORD=changeme123
SUPERADMIN_NAME=System Administrator
