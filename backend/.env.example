GEMINI_API_KEY=your_free_tier_key_here
EMBED_MODEL=models/gemini-embedding-001     # 768-d, used for pgvector RAG
LLM_MODEL=gemini-2.5-flash

# --- Auth / RBAC ---
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720
# Postgres. Supabase: use the session-pooler URL (IPv4); scheme auto-normalized to psycopg.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# Bootstrap super-admin (created on first startup if absent)
SUPERADMIN_NIC=199000000000
SUPERADMIN_PASSWORD=changeme123
SUPERADMIN_NAME=System Administrator

# --- Supabase Storage (private 'documents' bucket + signed URLs) ---
# Real values go in backend/.env (gitignored). NEVER put real secrets in this tracked template.
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx     # client-side (frontends)
SUPABASE_SECRET_KEY=sb_secret_xxx                          # SECRET: backend storage ops (dashboard -> Settings -> API)
SUPABASE_BUCKET=documents
SIGNED_URL_TTL=3600
