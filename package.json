{
  "name": "govpath-db",
  "version": "1.0.0",
  "private": true,
  "description": "Prisma tooling for the GovPath Postgres database (schema, migrations, Studio). The app itself is FastAPI (backend/) + Next.js (admin_web/) + Flutter (mobile/).",
  "scripts": {
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
